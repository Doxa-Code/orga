{
  "name": "orga",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "sh ./scripts/dev.sh",
    "test": "export NODE_ENV=test; npm run service:dev:start && turbo test --parallel; npm run service:dev:stop",
    "format": "biome format --write .",
    "lint": "npm run format && turbo lint && manypkg fix",
    "service:dev:start": "npm run docker:compose:dev -- up -d && npm run create:bucket:dev",
    "service:dev:stop": "npm run docker:compose:dev -- stop",
    "docker:compose:dev": "docker compose -f ./config/infrastructure/docker-compose-dev.yml",
    "database:seed": "bun run ./config/seed",
    "database:setup": "npx prisma generate --schema packages/core/infra/drivers/prisma/schema.prisma",
    "setup": "npm run database:setup",
    "create:bucket:dev": "sh ./scripts/create:bucket:dev.sh"
  },
  "dependencies": {
    "@biomejs/biome": "1.8.3",
    "@manypkg/cli": "^0.21.4",
    "@radix-ui/react-tabs": "^1.1.0",
    "turbo": "^2.1.3",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.11.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "config/*"
  ]
}
