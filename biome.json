{
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "ignore": ["node_modules", ".next"],
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "noSvgWithoutTitle": "off",
        "useAriaPropsForRole": "off",
        "useKeyWithClickEvents": "off",
        "useButtonType": "off"
      },
      "style": {
        "noNonNullAssertion": "off"
      },
      "correctness": {
        "useExhaustiveDependencies": "off"
      },
      "complexity": {
        "noStaticOnlyClass": "off",
        "noThisInStatic": "off",
        "noForEach": "off"
      },
      "performance": {
        "noDelete": "off"
      },
      "suspicious": {
        "noMisleadingCharacterClass": "off",
        "noExplicitAny": "off",
        "noArrayIndexKey": "off",
        "noGlobalIsNan": "off",
        "noGlobalIsFinite": "off",
        "noConfusingVoidType": "off"
      }
    }
  },
  "formatter": {
    "indentStyle": "space"
  }
}
